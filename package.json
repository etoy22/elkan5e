{
	"name": "elkan5e",
	"version": "1.0.0",
	"description": "![GitHub Downloads](https://img.shields.io/github/downloads/etoy22/elkan5e/module.zip?color=blue)",
	"main": "elkan5e.mjs",
	"type": "module",
	"scripts": {
		"pack": "node ./scripts/pack-chain.mjs",
		"clean": "npm run fix && npm run build:clean",
		"unpack": "node ./scripts/packs.mjs package unpack",
		"build:clean": "node ./scripts/packs.mjs package clean",
		"build:db": "node ./scripts/packs.mjs package pack",
		"remove": "node ./scripts/packs.mjs package remove",
		"lint": "eslint \"src/**/*.mjs\" \"scripts/**/*.mjs\"",
		"lint:fix": "eslint --fix \"src/**/*.mjs\" \"scripts/**/*.mjs\"",
		"format": "prettier --config .prettierrc.json --write \"src/**/*.{js,mjs,json,md}\" \"scripts/**/*.{js,mjs,json,md}\"",
		"test": "node --test scripts/tests.mjs",
		"fix": "npm run lint:fix && npm run format"
	},
	"devDependencies": {
		"@foundryvtt/foundryvtt-cli": "^3.0.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"node-fetch": "^3.3.2",
		"prettier": "^3.8.3",
		"yaml": "^2.8.3"
	},
	"dependencies": {
		"@foundryvtt/foundryvtt-cli": "^3.0.3",
		"fancy-log": "^2.0.0",
		"level": "^10.0.0",
		"yargs": "^18.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/etoy22/elkan5e.git"
	},
	"author": "Ethan Leider",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/etoy22/elkan5e/issues"
	},
	"homepage": "https://github.com/etoy22/elkan5e#readme"
}
