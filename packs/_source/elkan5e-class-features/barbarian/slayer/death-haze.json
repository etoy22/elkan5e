	"name": "Death Haze",
	"type": "feat",
	"img": "icons/magic/unholy/beams-impact-pink.webp",
	"system": {
		"description": {
			"value": "<p><em>When you enter rage, you feel as though you are dying, passing part way into the veil between life and death.</em></p><p>While raging, you gain the following benefits:</p><ul><li><p>You are resistant to &amp;reference[necrotic] damage.</p></li><li><p>You are immune to the &amp;reference[drained] and &amp;reference[exhaustion] conditions, and those conditions are removed from you when you enter rage.</p></li><li><p>You are immune to any effect that ages you or which can instantly drop you to 0 hit points. These effects, such as a ghost's horrifying visage or wail of the banshee, deal no damage to you.</p></li></ul>",
			"chat": ""
		},
