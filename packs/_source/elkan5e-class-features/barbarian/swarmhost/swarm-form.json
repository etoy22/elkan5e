	"name": "Swarm Form",
	"type": "feat",
	"img": "icons/magic/unholy/strike-body-explode-disintegrate.webp",
	"system": {
		"description": {
			"value": "<p><em>When you enter rage, you transform yourself into a humanoid swarm.</em></p><p><strong>No Action Cost</strong> - Magical</p><ul><li><p>You are immune to the &amp;reference[grappled], &amp;reference[petrified], &amp;reference[prone], and &amp;reference[restrained] conditions.</p></li><li><p>You choose whether your equipment is carried by your new form or dropped.</p></li><li><p>You can move through any other creatures at full speed, and can squeeze through gaps as small as 1 inch wide, though your equipment may be left behind in the process.</p></li></ul><p>Starting at level 6:</p><ul><li><p>You gain a flying speed equal to your walking speed.</p></li></ul>",
			"chat": ""
		},
