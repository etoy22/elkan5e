	"system": {
		"description": {
			"value": "<p><em>If the [[lookup @name lowercase]] moves at least 20 feet straight toward a creature and hits it with a claw attack on the same turn, the target must make a Strength saving throw to avoid being knocked prone.</em></p><p><strong>[[/save str]]{Strength Save}</strong></p><ul><li><p><strong>Failure:</strong> The target is knocked prone.</p></li><li><p><strong>Success:</strong> The target remains standing.</p></li></ul><p><strong>Follow-up:</strong> If the target is prone, the [[lookup @name lowercase]] can make one bite attack against it as a bonus action.</p>",
