{
	"name": "Dreadful Glare",
	"type": "feat",
	"img": "icons/magic/perception/hand-eye-pink.webp",
	"system": {
		"description": {
			"value": "<p><em>The [[lookup @name lowercase]] fixes a dreadful glare on one creature it can see within 60 feet. If the creature can see the [[lookup @name lowercase]], it must make a <strong>DC 16 Wisdom</strong> saving throw or suffer the laughter‑like terror.</em></p><p><strong>[[/save wis]]{Wisdom Save}</strong></p><ul><li><p><strong>Failure:</strong> The target is frightened until the end of the [[lookup @name lowercase]]'s next turn. If the save fails by 5 or more, the target is also paralyzed for that duration.</p></li><li><p><strong>Success:</strong> No effect, and the target is immune to the Dreadful Glare of all mummies and the [[lookup @name lowercase]] for the next 24 hours.</p></li></ul>",
