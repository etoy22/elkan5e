	"system": {
		"description": {
			"value": "<p><em>You toss phosphorus down at your feet, and a moment later, a wall of flames flashes into existence where you will it.</em></p><p><strong>[[/save dexterity]]{Dexterity Save}</strong></p><ul><li><p><strong>Failure:</strong> Target takes [[/damage 5d8 fire]] damage.*</p></li><li><p><strong>Success:</strong> Half damage.</p></li><li><p><strong>Area Hazard:</strong> The area covered by the wall is &amp;reference[heavily obscured]. Targets roll a save when they enter or when they end their turn in the wall (but only once per turn).</p></li></ul><p><strong>*Upcasting:</strong> Increase damage by [[/damage 1d8 fire]]{1d8} for each spell level above 4th.</p>",
			"chat": ""
		},
