	"system": {
		"description": {
			"value": "<p><em>Reaching out to your foes, you call upon nature to spring forth and hold them in place.</em></p><p><strong>[[/save str]]{Strength Save}</strong></p><ul><li><p><strong>Failure:</strong> Target is &amp;reference[grappled] by the entangling plants until the spell ends. Target rolls again at end of their turns, ending effect on success.</p></li><li><p><strong>Success:</strong> No effect.</p></li><li><p><strong>Area Hazard:</strong> The area is &amp;reference[difficult terrain]. Creatures who enter the area are not &amp;reference[grappled apply=false].</p></li></ul>",
			"chat": ""
		},
